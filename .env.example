# Claude API 키 (대본 생성) - https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Pexels API 키 (무료 스톡 영상) - https://www.pexels.com/api/
PEXELS_API_KEY=

# YouTube OAuth 클라이언트 파일 경로 (Google Cloud Console에서 다운로드)
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# TTS 기본 음성 (ko-KR-SunHiNeural=여성, ko-KR-InJoonNeural=남성)
DEFAULT_VOICE=ko-KR-SunHiNeural
